# Runtime environment
APP_NAME=Employee Salary API
ENVIRONMENT=development

# SQLite database URL.
# Local default:
DATABASE_URL=sqlite:///./employee_salary.db

# Docker Compose default:
# DATABASE_URL=sqlite:////app/data/employee_salary.db

# API server settings used by docker-compose.yml.
API_HOST=0.0.0.0
API_PORT=8000
